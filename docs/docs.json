{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Take Time",
  "colors": {
    "primary": "#007AFF",
    "light": "#5AC8FA",
    "dark": "#0056CC"
  },
  "font": {
    "headings": {
      "family": "SF Pro Display, -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "weight": 700
    },
    "body": {
      "family": "SF Pro Text, -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "rounded": "default",
  "navigation": {
    "anchors": [
      {
        "anchor": "Documentation",
        "icon": "book-open",
        "tabs": [
          {
            "tab": "Documentation",
            "groups": [
              {
                "group": "Get Started",
                "pages": [
                  "introduction",
                  "quickstart",
                  "authentication"
                ]
              },
              {
                "group": "Core Concepts",
                "pages": [
                  "concepts/blocks",
                  "concepts/subjects",
                  "concepts/schedule",
                  "concepts/stats"
                ]
              },
              {
                "group": "Guides",
                "pages": [
                  "guides/production"
                ]
              }
            ]
          },
          {
            "tab": "MCP Server",
            "groups": [
              {
                "group": "MCP Server",
                "pages": [
                  "mcp/overview",
                  "mcp/installation",
                  "mcp/tools",
                  "mcp/examples"
                ]
              }
            ]
          }
        ]
      },
      {
        "anchor": "GitHub",
        "href": "https://github.com/KenioCLG/take-time",
        "icon": "github"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "App",
